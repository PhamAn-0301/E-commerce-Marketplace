<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Multi-Vendor E-commerce Marketplace</title>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body>
    <header>
        <h1>Chào mừng đến với Marketplace</h1>
        <nav>
            <a href="/">Trang chủ</a>
            <a href="/login">Đăng nhập</a>
            <a href="/register">Đăng ký</a>
        </nav>
    </header>
    <main>
        <h2>Sản phẩm nổi bật</h2>
        <div class="products">
            <!-- Sản phẩm demo -->
            <div class="product-card">
                <img src="/public/demo-product.jpg" alt="Demo Product">
                <h3>Sản phẩm A</h3>
                <p>Giá: 100.000đ</p>
            </div>
            <div class="product-card">
                <img src="/public/demo-product.jpg" alt="Demo Product">
                <h3>Sản phẩm B</h3>
                <p>Giá: 200.000đ</p>
            </div>
        </div>
    </main>
    <footer>
        <p>&copy; 2026 Marketplace</p>
    </footer>
</body>
</html>
